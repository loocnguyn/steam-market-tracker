# --- Supabase ---
# Project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Keep this SERVER-ONLY. Used by the background poller / snapshot writer.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Steam ---
# Required ONLY for price history charts (pricehistory endpoint).
# Value of the `steamLoginSecure` cookie from a logged-in Steam session.
# Expires periodically and must be refreshed. Leave blank to disable charts
# and fall back to snapshot-built charts.
STEAM_LOGIN_COOKIE=

# Optional secret to protect the background poller / cron endpoint.
CRON_SECRET=change-me

# Signs the "Sign in through Steam" session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
